{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "2.0.1",
  "default_locale": "en",
  "minimum_chrome_version": "111",

  "permissions": [
    "storage",
    "activeTab",
    "identity"
  ],

  "host_permissions": [
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "https://api.groq.com/*",
    "https://ollama.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://smvnsfznxctkegjbckmt.supabase.co/*"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://youtu.be/*"
      ],
      "exclude_matches": [
        "https://music.youtube.com/*"
      ],
      "js": ["content/page-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://youtube.com/*",
        "https://youtu.be/*"
      ],
      "exclude_matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "utils/fingerprintjs.min.js",
        "utils/fingerprint.js",
        "utils/storage.js",
        "utils/supabase-auth.js",
        "utils/api-client.js",
        "content/transcript.js",
        "content/podcast.js",
        "utils/gemini-pcm-wav.js",
        "content/ui.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
